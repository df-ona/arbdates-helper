{
  "manifest_version": 3,
  "name": "ArbDates Helper",
  "version": "2.1.0",
  "description": "Select arbitrators and dates on arbdates.com and generate email-ready availability summaries.",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["https://www.arbdates.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.arbdates.com/*"],
      "js": ["content/content.js"],
      "css": ["content/panel.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Toggle ArbDates Helper",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  }
}
